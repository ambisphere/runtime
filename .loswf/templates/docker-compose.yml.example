# loswf2 semantic index stack — see docs/CODE_SEARCH.md and specs/SRS.md §4.7
# Start with: docker compose -f .loswf/templates/docker-compose.yml.example up -d
# Then:       ollama pull mxbai-embed-large

services:
  qdrant:
    image: qdrant/qdrant:latest
    ports:
      - "6333:6333"
    volumes:
      - ./.loswf/state/qdrant:/qdrant/storage

  ollama:
    image: ollama/ollama:latest
    ports:
      - "11434:11434"
    volumes:
      - ./.loswf/state/ollama:/root/.ollama
