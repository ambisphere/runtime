{
  "env": {
    "LOSWF_SELF_HOSTED": "1"
  },
  "showThinkingSummaries": true,
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh",
    "refreshInterval": 5,
    "padding": 1
  },
  "permissions": {
    "allow": [
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh label:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(git worktree:*)"
    ],
    "deny": [
      "Bash(*--no-verify*)",
      "Bash(gh pr merge*--admin*)",
      "Bash(git branch -D main*)",
      "Bash(git branch -D master*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git reset --hard origin/main*)",
      "Bash(git reset --hard origin/master*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Read(**/.env)",
      "Read(**/credentials.json)",
      "Read(**/id_ed25519)",
      "Read(**/id_rsa)",
      "Read(.env)",
      "Read(.env.*)",
      "Write(**/.env)",
      "Write(.env)",
      "Write(.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/loswf_pre_tool_use.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validators/loswf_label_transition.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validators/loswf_commit_message.py"
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validators/loswf_branch_guard.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validators/loswf_plan_required.py"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/loswf_subagent_marker.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/loswf_post_tool_use_log.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/loswf_post_edit_index.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/loswf_post_agent.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/loswf_post_agent.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/loswf_subagent_marker.py"
          }
        ]
      }
    ]
  }
}
